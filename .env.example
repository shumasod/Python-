# ============================================================
# 環境変数サンプル
# cp .env.example .env して値を設定してください
# .env は .gitignore に追加し、絶対にコミットしないこと
# ============================================================

# アプリ設定
LOG_LEVEL=INFO
MODEL_NAME=boat_race_model

# データベース
DB_HOST=localhost
DB_PORT=5432
DB_NAME=boatracedb
DB_USER=admin
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# AWS（ローカルではダミー値でOK）
AWS_DEFAULT_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=boat-race-ai-data-prod
