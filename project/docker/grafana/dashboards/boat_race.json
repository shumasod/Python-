{
  "title": "競艇予想AI - 監視ダッシュボード",
  "uid": "boat-race-main",
  "version": 1,
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "予測リクエスト数 (req/s)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(boat_race_predictions_total[1m])",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "予測レイテンシ P95 (ms)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(boat_race_prediction_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "P95"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, rate(boat_race_prediction_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "P50"
        }
      ]
    },
    {
      "id": 3,
      "title": "キャッシュヒット率 (%)",
      "type": "stat",
      "gridPos": {"x": 0, "y": 8, "w": 6, "h": 6},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(boat_race_cache_hits_total[5m]) / (rate(boat_race_cache_hits_total[5m]) + rate(boat_race_cache_misses_total[5m])) * 100",
          "legendFormat": "Hit Rate %"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 4,
      "title": "ドリフトアラート数",
      "type": "stat",
      "gridPos": {"x": 6, "y": 8, "w": 6, "h": 6},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "boat_race_drift_alerts_total",
          "legendFormat": "Alerts"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "thresholds": {
          "steps": [
            {"color": "green", "value": 0},
            {"color": "yellow", "value": 1},
            {"color": "red", "value": 5}
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "モデルバージョン情報",
      "type": "stat",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 6},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "boat_race_model_info",
          "legendFormat": "{{version}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "CPU 使用率 (%)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 14, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %"
        }
      ]
    },
    {
      "id": 7,
      "title": "メモリ使用量 (MB)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 14, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / 1024 / 1024",
          "legendFormat": "Used MB"
        }
      ]
    },
    {
      "id": 8,
      "title": "Redis メモリ使用量 (MB)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 22, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "redis_memory_used_bytes / 1024 / 1024",
          "legendFormat": "Redis Used MB"
        }
      ]
    },
    {
      "id": 9,
      "title": "HTTP エラー率 (%)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 22, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(boat_race_predictions_total{status=~\"4..|5..\"}[5m]) / rate(boat_race_predictions_total[5m]) * 100",
          "legendFormat": "Error Rate %"
        }
      ]
    }
  ],
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {}
}
