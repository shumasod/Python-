# ============================================================
# Terraform 変数サンプル
# cp terraform.tfvars.example terraform.tfvars して値を設定
# terraform.tfvars は .gitignore に追加し絶対にコミットしないこと
# ============================================================

# --- 基本設定 ---
project_name = "boat-race-ai"
environment  = "prod"
aws_region   = "ap-northeast-1"

# --- ネットワーク ---
vpc_cidr             = "10.0.0.0/16"
availability_zones   = ["ap-northeast-1a", "ap-northeast-1c"]
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24"]

# --- ECS Fargate ---
# コスト最適化: 開発は 256/512、本番は 512/1024 以上
ecs_cpu           = 512
ecs_memory        = 1024
ecs_desired_count = 2
ecr_image_tag     = "latest"

# --- RDS ---
# コスト最適化: 開発は db.t3.micro（無料枠対象）
db_instance_class    = "db.t3.micro"
db_name              = "boatracedb"
db_username          = "admin"
db_password          = "CHANGE_ME_STRONG_PASSWORD_HERE"  # 本番では Secrets Manager を使用
db_allocated_storage = 20

# --- S3 ---
s3_data_retention_days = 365  # 1年後に自動削除

# --- CloudWatch ---
log_retention_days = 30

# --- 共通タグ ---
tags = {
  Project     = "boat-race-ai"
  Environment = "prod"
  ManagedBy   = "terraform"
  CostCenter  = "ml-team"
}
